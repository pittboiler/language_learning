# Copy this file to `.env` and fill in the three credentials below.
# `.env` and the Google key file are gitignored — never commit them.

# ---- Anthropic (tutor + feedback LLM) -------------------------------------
# You already have this. Standalone API key, separate from Claude Code.
ANTHROPIC_API_KEY=sk-ant-...

# ---- ElevenLabs (Macedonian TTS + Scribe ASR) -----------------------------
# One key covers both. Get it at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Optional: pin a specific Macedonian-capable voice. Leave blank to let the
# app pick a multilingual voice for you.
ELEVENLABS_VOICE_ID=

# ---- Google Cloud Speech-to-Text (second ASR engine) ----------------------
# Google STT does NOT accept a plain API key. It needs a service-account JSON
# file. Download it (see README step 5), drop it in this folder as
# `gcp-stt-key.json`, and leave this var pointing at it:
GOOGLE_APPLICATION_CREDENTIALS=./gcp-stt-key.json

# ---- Local server ---------------------------------------------------------
PORT=5050
