# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# --- Anthropic (tutor + feedback LLM) ---
ANTHROPIC_API_KEY=

# --- ElevenLabs (Macedonian TTS + Scribe ASR) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Google Cloud Speech-to-Text (second ASR engine) ---
# Local dev: absolute path to the service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
# Serverless (Vercel): paste the service-account JSON inline instead of a file path.
# GOOGLE_CREDENTIALS_JSON=

# --- Supabase (persistence / anon auth / audio storage) — see SUPABASE_SETUP.md ---
# Project URL + publishable("public")/secret("private") keys. Empty ⇒ app uses localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
